<view class="page-container data-v-e1b4016f"><view class="contract-list data-v-e1b4016f"><view wx:for="{{a}}" wx:for-item="contract" wx:key="j" class="contract-card data-v-e1b4016f"><view class="contract-header data-v-e1b4016f"><view class="contract-room data-v-e1b4016f">{{contract.a}}</view><view class="{{['contract-status', 'data-v-e1b4016f', contract.c]}}">{{contract.b}}</view></view><view class="contract-body data-v-e1b4016f"><view class="contract-tenant data-v-e1b4016f">租客：{{contract.d}}</view><view class="contract-info data-v-e1b4016f"><view class="info-item data-v-e1b4016f"><text class="info-label data-v-e1b4016f">租期</text><text class="info-value data-v-e1b4016f">{{contract.e}} ~ {{contract.f}}</text></view><view class="info-item data-v-e1b4016f"><text class="info-label data-v-e1b4016f">月租金</text><text class="info-value price data-v-e1b4016f">¥{{contract.g}}</text></view></view></view><view wx:if="{{contract.h}}" class="contract-actions data-v-e1b4016f"><button class="btn-terminate data-v-e1b4016f" bindtap="{{contract.i}}">解约</button></view></view><view wx:if="{{b}}" class="empty data-v-e1b4016f"><text class="empty-icon data-v-e1b4016f">📝</text><text class="data-v-e1b4016f">暂无合同</text></view></view><view class="add-btn data-v-e1b4016f" bindtap="{{c}}"><text class="data-v-e1b4016f">+</text></view><view wx:if="{{d}}" class="modal data-v-e1b4016f"><view class="modal-content data-v-e1b4016f"><view class="popup-title data-v-e1b4016f">签订合同</view><view class="form-item data-v-e1b4016f"><text class="form-label data-v-e1b4016f">选择房间</text><picker class="data-v-e1b4016f" range="{{f}}" range-key="room_number" bindchange="{{g}}"><view class="form-picker data-v-e1b4016f">{{e}} ›</view></picker></view><view class="form-item data-v-e1b4016f"><text class="form-label data-v-e1b4016f">选择租客</text><picker class="data-v-e1b4016f" range="{{i}}" range-key="name" bindchange="{{j}}"><view class="form-picker data-v-e1b4016f">{{h}} ›</view></picker></view><view class="form-item data-v-e1b4016f"><text class="form-label data-v-e1b4016f">开始日期</text><picker class="data-v-e1b4016f" mode="date" value="{{l}}" bindchange="{{m}}"><view class="form-picker data-v-e1b4016f">{{k}} ›</view></picker></view><view class="form-item data-v-e1b4016f"><text class="form-label data-v-e1b4016f">结束日期</text><picker class="data-v-e1b4016f" mode="date" value="{{o}}" bindchange="{{p}}"><view class="form-picker data-v-e1b4016f">{{n}} ›</view></picker></view><view class="form-item data-v-e1b4016f"><text class="form-label data-v-e1b4016f">月租金</text><input class="form-input data-v-e1b4016f" type="digit" placeholder="请输入" value="{{q}}" bindinput="{{r}}"/></view><button class="btn-primary data-v-e1b4016f" bindtap="{{t}}" disabled="{{v}}">{{s}}</button><button class="btn-default data-v-e1b4016f" bindtap="{{w}}">取消</button></view></view></view>